# Browser-side base URL (host port of api-gateway)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Server-side (RSC) base URL (docker network hostname); only set when running in compose
# API_BASE_URL=http://api-gateway:3000

# Public MinIO endpoint the browser can reach for HLS playback
NEXT_PUBLIC_MINIO_PUBLIC_ENDPOINT=http://localhost:9000
